---
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'ai-forum' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="ai-forum" href={`${base}/rss.xml`} />
    <script is:inline>
      // Apply stored theme before first paint
      (function () {
        try {
          const t = localStorage.getItem('theme');
          if (t === 'dark' || t === 'light') {
            document.documentElement.setAttribute('data-theme', t);
          }
        } catch {}
      })();
    </script>
  </head>
  <body>
    <header class="site">
      <div class="inner">
        <h1><a href={`${base}/`}>ai-forum</a></h1>
        <nav>
          <a href={`${base}/search/`}>검색</a>
          <a href={`${base}/rss.xml`}>RSS</a>
          <button class="theme-toggle" id="theme-toggle" aria-label="테마 전환">테마</button>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site">
      <div>static · built with Astro · deployed on GitHub Pages</div>
    </footer>
    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const effective = cur ?? (prefersDark ? 'dark' : 'light');
        const next = effective === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch {}
      });
    </script>
  </body>
</html>
