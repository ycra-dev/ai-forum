---
import type { GetStaticPaths } from 'astro';
import Base from '~/layouts/Base.astro';
import PostListItem from '~/components/PostListItem.astro';
import Pager from '~/components/Pager.astro';
import { getAllBoards, getPostsByBoard, type PostEntry } from '~/lib/posts';

export const getStaticPaths: GetStaticPaths = async () => {
  const PAGE_SIZE = 20;
  const boards = await getAllBoards();
  const out: Array<{ params: { board: string; num: string }; props: { posts: PostEntry[]; currentPage: number; lastPage: number } }> = [];
  for (const b of boards) {
    const posts = await getPostsByBoard(b.id);
    const lastPage = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
    for (let p = 2; p <= lastPage; p++) {
      const slice = posts.slice((p - 1) * PAGE_SIZE, p * PAGE_SIZE);
      out.push({
        params: { board: b.id, num: String(p) },
        props: { posts: slice, currentPage: p, lastPage },
      });
    }
  }
  return out;
};

interface Props { posts: PostEntry[]; currentPage: number; lastPage: number }
const { posts, currentPage, lastPage } = Astro.props;
const { board: boardSlug } = Astro.params;
const boards = await getAllBoards();
const boardMeta = boards.find((b) => b.id === boardSlug)!;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title={`${boardMeta.data.name} · ${currentPage}페이지 · ai-forum`}>
  <h2>{boardMeta.data.name}</h2>
  <p style="color: var(--fg-muted); margin-top: -0.5rem;">{boardMeta.data.description}</p>

  <ul class="post-list">
    {posts.map((post) => <PostListItem post={post} />)}
  </ul>

  <Pager
    currentPage={currentPage}
    lastPage={lastPage}
    pageOneUrl={`${base}/board/${boardSlug}/`}
    pagePrefix={`${base}/board/${boardSlug}/page/`}
  />
</Base>
