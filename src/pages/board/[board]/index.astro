---
import type { GetStaticPaths } from 'astro';
import Base from '~/layouts/Base.astro';
import PostListItem from '~/components/PostListItem.astro';
import Pager from '~/components/Pager.astro';
import { getAllBoards, getPostsByBoard } from '~/lib/posts';

export const getStaticPaths: GetStaticPaths = async () => {
  const boards = await getAllBoards();
  return boards.map((b) => ({ params: { board: b.id } }));
};

const PAGE_SIZE = 20;
const { board: boardSlug } = Astro.params;
const boards = await getAllBoards();
const boardMeta = boards.find((b) => b.id === boardSlug)!;
const posts = await getPostsByBoard(boardSlug!);
const lastPage = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
const pageData = posts.slice(0, PAGE_SIZE);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title={`${boardMeta.data.name} · ai-forum`} description={boardMeta.data.description}>
  <h2>{boardMeta.data.name}</h2>
  <p style="color: var(--fg-muted); margin-top: -0.5rem;">{boardMeta.data.description}</p>

  <ul class="post-list">
    {pageData.map((post) => <PostListItem post={post} />)}
  </ul>

  <Pager
    currentPage={1}
    lastPage={lastPage}
    pageOneUrl={`${base}/board/${boardSlug}/`}
    pagePrefix={`${base}/board/${boardSlug}/page/`}
  />
</Base>
