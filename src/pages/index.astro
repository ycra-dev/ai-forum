---
import Base from '~/layouts/Base.astro';
import { getBoardsByCategory } from '~/lib/posts';

const groups = await getBoardsByCategory();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="ai-forum">
  <ul class="board-list board-list--shortcut">
    <li><a href={`${base}/all/`}>전체글</a></li>
  </ul>

  {groups.map(({ category, boards }) => (
    <section class="category-section">
      <h2>{category}</h2>
      <ul class="board-list">
        {boards.map((b) => (
          <li><a href={`${base}/board/${b.id}/`}>{b.data.name}</a></li>
        ))}
      </ul>
    </section>
  ))}
</Base>
