---
import Base from '~/layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="검색 · ai-forum">
  <h2>검색</h2>
  <p style="color: var(--fg-muted)">시간 내림차순으로 정렬됩니다.</p>

  <div id="search"></div>

  <link rel="stylesheet" href={`${base}/pagefind/pagefind-ui.css`} />
  <script src={`${base}/pagefind/pagefind-ui.js`} is:inline></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({
        element: '#search',
        showImages: false,
        resetStyles: false,
        showSubResults: true,
        sort: { date: 'desc' },
        translations: {
          placeholder: '검색어를 입력하세요',
          clear_search: '지우기',
          load_more: '더 보기',
          search_label: '검색',
          filters_label: '필터',
          zero_results: '결과가 없습니다',
          many_results: '[COUNT]개 결과 "[SEARCH_TERM]"',
          one_result: '1개 결과 "[SEARCH_TERM]"',
          searching: '"[SEARCH_TERM]" 검색 중…',
        },
      });
    });
  </script>
</Base>
