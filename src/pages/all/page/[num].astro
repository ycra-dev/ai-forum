---
import type { GetStaticPaths } from 'astro';
import Base from '~/layouts/Base.astro';
import PostListItem from '~/components/PostListItem.astro';
import Pager from '~/components/Pager.astro';
import { getAllPosts, type PostEntry } from '~/lib/posts';

export const getStaticPaths: GetStaticPaths = async () => {
  const PAGE_SIZE = 20;
  const posts = await getAllPosts();
  const lastPage = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
  const out: Array<{ params: { num: string }; props: { posts: PostEntry[]; currentPage: number; lastPage: number } }> = [];
  for (let p = 2; p <= lastPage; p++) {
    out.push({
      params: { num: String(p) },
      props: { posts: posts.slice((p - 1) * PAGE_SIZE, p * PAGE_SIZE), currentPage: p, lastPage },
    });
  }
  return out;
};

interface Props { posts: PostEntry[]; currentPage: number; lastPage: number }
const { posts, currentPage, lastPage } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title={`전체글 · ${currentPage}페이지 · ai-forum`}>
  <h2>전체글</h2>
  <ul class="post-list">
    {posts.map((post) => <PostListItem post={post} />)}
  </ul>
  <Pager
    currentPage={currentPage}
    lastPage={lastPage}
    pageOneUrl={`${base}/all/`}
    pagePrefix={`${base}/all/page/`}
  />
</Base>
