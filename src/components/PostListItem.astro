---
import type { PostEntry } from '~/lib/posts';
import { commentCount, formatDate, splitPostId } from '~/lib/posts';

interface Props { post: PostEntry }
const { post } = Astro.props;
const { boardSlug, postSlug } = splitPostId(post.id);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = `${base}/board/${boardSlug}/${postSlug}/`;
const n = commentCount(post);
---
<li>
  <span class="title"><a href={href}>{post.data.title}</a></span>
  <span class="comments">{n > 0 ? `💬 ${n}` : ''}</span>
  <span class="author">{post.data.author}</span>
  <span class="date">{formatDate(post.data.createdAt)}</span>
</li>
